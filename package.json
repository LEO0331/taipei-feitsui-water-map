{
  "name": "taipei-feitsui-water-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "test": "npm run test:unit && tsc --noEmit",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "fetch:water": "tsx scripts/fetchFeitsuiWaterResources.ts",
    "fetch:hydromet": "tsx scripts/fetchFeitsuiHydrometResources.ts",
    "fetch:operation": "tsx scripts/fetchFeitsuiOperationResources.ts",
    "data:fetch:river-water": "tsx scripts/fetchRiverWaterQuality.ts",
    "data:fetch:pumping-stations": "tsx scripts/fetchPumpingStations.ts",
    "data:fetch:twc-support": "tsx scripts/fetchTaipeiWaterSupportTwcMonthlyStatistics.ts",
    "data:fetch:park-water-safety": "tsx scripts/fetchParkWaterSafetyEquipment.ts",
    "data:fetch:clear-water-quality": "tsx scripts/fetchTreatmentPlantClearWaterQuality.ts",
    "data:convert:pumping-stations": "tsx scripts/convertPumpingStations.ts && tsx scripts/buildPumpingStationSummary.ts",
    "data:convert:twc-support": "tsx scripts/convertTaipeiWaterSupportTwcMonthlyStatistics.ts && tsx scripts/buildTaipeiWaterSupportTwcSummary.ts",
    "data:convert:park-water-safety": "tsx scripts/convertParkWaterSafetyEquipment.ts && tsx scripts/buildParkWaterSafetyEquipmentSummary.ts",
    "data:convert:clear-water-quality": "tsx scripts/convertTreatmentPlantClearWaterQuality.ts && tsx scripts/buildTreatmentPlantClearWaterQualitySummary.ts",
    "fetch:data": "npm run fetch:water && npm run fetch:hydromet && npm run fetch:operation && npm run data:fetch:river-water && npm run data:fetch:twc-support && npm run data:fetch:park-water-safety && npm run data:fetch:clear-water-quality",
    "convert:water": "tsx scripts/convertFeitsuiWaterQuality.ts",
    "convert:hydromet": "tsx scripts/convertFeitsuiHydromet.ts",
    "convert:operation": "tsx scripts/convertFeitsuiOperation.ts",
    "data:convert:river-water": "tsx scripts/convertRiverWaterQuality.ts && tsx scripts/buildRiverWaterQualitySummary.ts",
    "convert:data": "npm run convert:water && npm run convert:hydromet && npm run convert:operation && tsx scripts/convertRiverWaterQuality.ts && npm run data:convert:pumping-stations && tsx scripts/buildRiverWaterQualitySummary.ts && npm run data:convert:twc-support && npm run data:convert:park-water-safety && npm run data:convert:clear-water-quality"
  },
  "dependencies": {
    "@types/proj4": "^2.5.6",
    "leaflet": "^1.9.4",
    "proj4": "^2.20.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
