{
  "name": "taipei-feitsui-water-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "test": "npm run test:unit && tsc --noEmit",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "fetch:water": "tsx scripts/fetchFeitsuiWaterResources.ts",
    "fetch:hydromet": "tsx scripts/fetchFeitsuiHydrometResources.ts",
    "fetch:data": "npm run fetch:water && npm run fetch:hydromet",
    "convert:water": "tsx scripts/convertFeitsuiWaterQuality.ts",
    "convert:hydromet": "tsx scripts/convertFeitsuiHydromet.ts",
    "convert:data": "npm run convert:water && npm run convert:hydromet"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "@types/leaflet": "^1.9.16",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
